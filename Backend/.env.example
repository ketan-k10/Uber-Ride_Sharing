# ── Backend environment variables ──
# Copy to `.env` for local dev, and set the same keys in your host (Render) dashboard.

# MongoDB connection string (e.g. from MongoDB Atlas)
DB_CONNECT=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smartride?retryWrites=true&w=majority

# Secret used to sign JWT auth tokens — use a long random string
JWT_SECRET=replace_with_a_long_random_secret

# Google Maps API key for SERVER-side calls (Geocoding + Distance Matrix + Places)
GOOGLE_MAPS_API=your_google_maps_server_key

# Gemini API key for the voice booking assistant (get one at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key
# Optional: override the Gemini model (defaults to gemini-3.1-flash-lite)
GEMINI_MODEL=gemini-3.1-flash-lite

# Port for local dev. On Render/most hosts this is injected automatically.
PORT=4000
